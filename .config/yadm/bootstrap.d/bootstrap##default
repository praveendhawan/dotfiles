# ---------------------------------------------------------------------------
# Neovim (NvChad + custom config)
# ---------------------------------------------------------------------------
if ! command -v nvim >/dev/null 2>&1; then
  load_brew_env
  brew install neovim
fi

if [ ! -d "$HOME/.config/nvim" ]; then
  git clone https://github.com/NvChad/NvChad "$HOME/.config/nvim" --depth 1
fi

if [ -d "$HOME/.config/nvim_custom" ] && [ ! -e "$HOME/.config/nvim/lua/custom" ]; then
  ln -s "$HOME/.config/nvim_custom" "$HOME/.config/nvim/lua/custom"
fi

# Launch nvim so Lazy runs and installs plugins interactively.
nvim

# ---------------------------------------------------------------------------
# Set zsh as default shell (done last so OMZ etc. are already in place)
# ---------------------------------------------------------------------------
if command -v zsh >/dev/null 2>&1; then
  current_shell="$(getent passwd "$USER" 2>/dev/null | cut -d: -f7 || dscl . -read "/Users/$USER" UserShell 2>/dev/null | awk '{print $2}')"
  zsh_path="$(command -v zsh)"
  if [ "$current_shell" != "$zsh_path" ]; then
    sudo chsh -s "$zsh_path" "$USER" || chsh -s "$zsh_path"
  fi
fi

echo "=== bootstrap complete: $(date) ==="
