#!/usr/bin/env bash
#
# Default bootstrap script, used on macOS and Debian/Ubuntu Linux.
# Arch Linux uses bootstrap##distro.arch,extension.sh instead.

set -eu

# ---------------------------------------------------------------------------
# Logging — tee stdout/stderr to a log file so failed runs are debuggable.
# ---------------------------------------------------------------------------
mkdir -p "$HOME/.cache"
exec > >(tee -a "$HOME/.cache/yadm-bootstrap.log") 2>&1
echo ""
echo "=== bootstrap run: $(date) ==="

SYSTEM_TYPE="$(uname -s)"

# Optional: create a new user account (Linux only, run as root).
# Set via env: NEW_USER=praveen ./bootstrap
NEW_USER="${NEW_USER:-}"

# Load brew into the current shell if it's installed but not on PATH yet
# (e.g. immediately after the Homebrew installer runs).
load_brew_env() {
  if command -v brew >/dev/null 2>&1; then
    return 0
  fi
  for candidate in \
    /opt/homebrew/bin/brew \
    /usr/local/bin/brew \
    /home/linuxbrew/.linuxbrew/bin/brew \
    "$HOME/.linuxbrew/bin/brew"; do
    if [ -x "$candidate" ]; then
      eval "$("$candidate" shellenv)"
      return 0
    fi
  done
  return 1
}

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
install_packages() {
  local packages=("$@")
  for package in "${packages[@]}"; do
    if ! dpkg -s "$package" >/dev/null 2>&1; then
      sudo apt install -y "$package"
    else
      echo "$package is already installed"
    fi
  done
}

# ---------------------------------------------------------------------------
# Oh My Zsh (install non-interactively so bootstrap doesn't get exec'd into zsh)
# ---------------------------------------------------------------------------
if [ ! -d "$HOME/.oh-my-zsh" ]; then
  RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
    sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi

ZSH_CUSTOM="${ZSH_CUSTOM:-$HOME/.oh-my-zsh/custom}"
if [ ! -d "$ZSH_CUSTOM/plugins/zsh-autosuggestions" ]; then
  git clone https://github.com/zsh-users/zsh-autosuggestions \
    "$ZSH_CUSTOM/plugins/zsh-autosuggestions"
fi

# ---------------------------------------------------------------------------
# macOS setup
# ---------------------------------------------------------------------------
if [ "$SYSTEM_TYPE" = "Darwin" ]; then
  if ! command -v brew >/dev/null 2>&1; then
    echo "Installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
  load_brew_env

  if [ -f "$HOME/.config/brewfile/.Brewfile" ]; then
    echo "Updating homebrew bundle"
    brew bundle --file="$HOME/.config/brewfile/.Brewfile"
  fi

  if [ -f "$HOME/.config/brewfile/.Brewfile.darwin" ]; then
    echo "Updating homebrew bundle for mac"
    brew bundle --file="$HOME/.config/brewfile/.Brewfile.darwin"
  fi

  # force the linking of libpq to avoid issues with installing pg gem
  if brew list libpq >/dev/null 2>&1; then
    brew link --force libpq
  fi
fi

# ---------------------------------------------------------------------------
# Debian/Ubuntu setup
# ---------------------------------------------------------------------------
if [ "$SYSTEM_TYPE" = "Linux" ]; then
  # Create a new user account if requested (set NEW_USER env var; typically
  # run as root during a fresh machine setup, then log back in as that user).
  if [ -n "$NEW_USER" ] && ! id -u "$NEW_USER" >/dev/null 2>&1; then
    sudo adduser "$NEW_USER"
  fi

  sudo apt update

  packages=(
    git
    build-essential
    libssl-dev
    libreadline-dev
    zlib1g-dev
    python3
    python3-pip
    zip
    unzip
    zsh
  )
  install_packages "${packages[@]}"

  # Linuxbrew
  if ! command -v brew >/dev/null 2>&1; then
    echo "Installing homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  fi
  load_brew_env

  if [ -f "$HOME/.config/brewfile/.Brewfile" ]; then
    echo "Updating homebrew bundle"
    brew bundle --file="$HOME/.config/brewfile/.Brewfile"
  fi

  if [ -f "$HOME/.config/brewfile/.Brewfile.linux" ]; then
    echo "Updating homebrew bundle for linux"
    brew bundle --file="$HOME/.config/brewfile/.Brewfile.linux"
  fi

  optional_packages=(
    libsqlite3-dev
    postgresql-13
    postgresql-client-13
    redis-server
    apt-transport-https
    elasticsearch=7.10.2
    kibana=7.10.2
  )

  for package in "${optional_packages[@]}"; do
    read -rp "Install optional package '$package'? (y/n) > " choice
    case "$choice" in
      y|Y) sudo apt install -y "$package" ;;
      *)   echo "Skipping $package" ;;
    esac
  done

  # Nerd font
  if fc-list | grep -iq "FiraMono"; then
    echo "FiraMono is already installed"
  else
    echo "Installing FiraMono"
    git clone --filter=blob:none --sparse https://github.com/ryanoasis/nerd-fonts
    ( cd nerd-fonts && ./install.sh FiraMono )
    rm -rf nerd-fonts
  fi

  # fd is packaged as fd-find on Debian/Ubuntu; expose it as `fd`
  if command -v fdfind >/dev/null 2>&1 && [ ! -e /usr/local/bin/fd ]; then
    sudo ln -s "$(command -v fdfind)" /usr/local/bin/fd
  fi
fi

# ---------------------------------------------------------------------------
# Language runtimes via mise (versions come from ~/.config/mise/config.toml,
# which is managed by yadm, so it's already on disk when this runs).
# ---------------------------------------------------------------------------
if ! command -v mise >/dev/null 2>&1; then
  load_brew_env
  brew install mise
fi
mise install

# ---------------------------------------------------------------------------
# Postgres superuser (Linux only — macOS uses brew services / different flow)
# ---------------------------------------------------------------------------
if [ "$SYSTEM_TYPE" = "Linux" ] && command -v psql >/dev/null 2>&1; then
  read -rp "Create a postgres superuser for '$USER'? (y/n) > " choice
  case "$choice" in
    y|Y)
      if ! sudo -u postgres psql -tAc "SELECT 1 FROM pg_roles WHERE rolname='$USER'" | grep -q 1; then
        sudo -u postgres createuser -s "$USER"
        sudo -u postgres createdb "$USER"
        sudo -u postgres psql -c "GRANT ALL PRIVILEGES ON DATABASE $USER TO $USER;"
      else
        echo "PostgreSQL role for '$USER' already exists"
      fi
      ;;
    *) echo "Skipping postgres user creation" ;;
  esac
fi

