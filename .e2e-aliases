# Gitlab cli Alias
alias gh="glab"
# SCP Aliases
SCP_CD="cd ~/workspace/Office/E2E/scp-backend/sovereign/"
LOCAL_SETTINGS="--settings=sovereign.config.dev_settings"
SCP_BASE_LOCAL="python manage.py "
alias pyc="$SCP_CD && $SCP_BASE_LOCAL shell $LOCAL_SETTINGS"
alias pys="$SCP_CD && $SCP_BASE_LOCAL runserver $LOCAL_SETTINGS"
alias pym="$SCP_CD && $SCP_BASE_LOCAL migrate $LOCAL_SETTINGS"
alias pymm="$SCP_CD && $SCP_BASE_LOCAL makemigrations $LOCAL_SETTINGS"
alias fes="cd ~/workspace/Office/E2E/awakening-admin && pnpm dev"
# alias cdb="mysql -u sovereign -p scp_db"
alias spy="$SCP_CD && $SCP_BASE_LOCAL"
alias celd="$SCP_CD && celery -A sovereign worker --loglevel=info -Q default -n short_worker@%h"
alias cello="$SCP_CD && celery -A sovereign worker --loglevel=info -Q migrations -n long_worker@%h"
alias esh="ssh -i ~/.ssh/e2eNew"
