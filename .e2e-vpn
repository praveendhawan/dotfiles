# VPN Aliases

# Get VPN Auth from proton cli - pass-cli
get_vpn_config() {
    local env="${1:-stage}"
    local vault="E2E"  # Your vault name
    local item

    case "$env" in
        stage|staging)
            item="VPN Stage Credentials"
            ;;
        prod|production)
            item="VPN Production Credentials"
            ;;
        *)
            echo "Error: Unknown environment '$env'" >&2
            echo "Available: stage, prod, dev" >&2
            return 1
            ;;
    esac

    echo "Retrieving $env config from ProtonPass..." >&2

    local data
    data=$(pass-cli item view --vault-name "$vault" --item-title "$item" --output json 2>/dev/null)

    if [ $? -ne 0 ]; then
        echo "Error: Failed to retrieve from ProtonPass" >&2
        return 1
    fi

    # Extract basic fields
    local username password host
    username=$(echo "$data" | jq -r '.item.content.content.Login.username')
    password=$(echo "$data" | jq -r '.item.content.content.Login.password')

    # Extract host from URLs (remove https:// and trailing /)
    host=$(echo "$data" | jq -r '.item.content.content.Login.urls[0]' | sed 's|https://||' | sed 's|/$||')

    # Extract from extra_fields
    local port cert
    port=$(echo "$data" | jq -r '.item.content.extra_fields[] | select(.name == "port") | .content.Text')
    cert=$(echo "$data" | jq -r '.item.content.extra_fields[] | select(.name == "cert") | .content.Hidden')

    # Return as JSON
    jq -n \
        --arg host "$host" \
        --arg port "$port" \
        --arg username "$username" \
        --arg password "$password" \
        --arg cert "$cert" \
        '{host: $host, port: $port, username: $username, password: $password, cert: $cert}'
}

# Connect to VPN
vpn_connect() {
    local env="${1:-stage}"

    echo "=== Connecting to $env VPN ==="

    # Get config from ProtonPass
    local config_json
    config_json=$(get_vpn_config "$env")

    if [ $? -ne 0 ]; then
        echo "Failed to retrieve VPN config" >&2
        return 1
    fi

    # Extract values
    local host port username password cert
    host=$(echo "$config_json" | jq -r '.host')
    port=$(echo "$config_json" | jq -r '.port')
    username=$(echo "$config_json" | jq -r '.username')
    password=$(echo "$config_json" | jq -r '.password')
    cert=$(echo "$config_json" | jq -r '.cert')

    # Validate required fields
    if [ -z "$host" ] || [ -z "$password" ]; then
        echo "Error: Missing required config (host or password)" >&2
        echo "Debug: host=$host, port=$port, username=$username" >&2
        return 1
    fi

    echo "✓ Config retrieved"
    echo "  Host: $host:$port"
    echo "  User: $username"
    [ -n "$cert" ] && [ "$cert" != "null" ] && echo "  Cert: ${cert:0:20}..."

    # Generate temp config on-the-fly
    local temp_config="/tmp/openfortivpn_${env}_$$.conf"

    cat > "$temp_config" << EOF
host = $host
port = ${port:-10443}
username = $username
password = $password
EOF

    # Add cert if present
    if [ -n "$cert" ] && [ "$cert" != "null" ]; then
        echo "trusted-cert = $cert" >> "$temp_config"
    fi

    chmod 600 "$temp_config"

    echo "Connecting..."
    sudo openfortivpn -c "$temp_config"

    # Cleanup
    rm -f "$temp_config"
    unset host port username password cert config_json
}

# Disconnect VPN
vpn_disconnect() {
    echo "Disconnecting VPN..."
    sudo killall openfortivpn 2>/dev/null
    if [ $? -eq 0 ]; then
        echo "✓ VPN disconnected"
    else
        echo "✗ VPN was not running"
    fi
}

# VPN Status
vpn_status() {
    if pgrep -x "openfortivpn" > /dev/null; then
        echo "✓ VPN is connected"
        ps aux | grep openfortivpn | grep -v grep | awk '{print "  PID:", $2, "Config:", $NF}'
        return 0
    else
        echo "✗ VPN is not connected"
        return 1
    fi
}

# Switch VPN to new env
vpn_switch() {
    local new_env="$1"

    if [ -z "$new_env" ]; then
        echo "Usage: vpn_switch {stage|prod|dev}"
        return 1
    fi

    # Disconnect current VPN if running
    if pgrep -x "openfortivpn" > /dev/null; then
        echo "Disconnecting current VPN..."
        sudo killall openfortivpn
        sleep 2
    fi

    # Connect to new environment
    vpn_connect "$new_env"
}

# Reconnect
vpn_reconnect() {
  vpn_disconnect
}
