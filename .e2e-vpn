# VPN Aliases — E2E (openfortivpn + ProtonPass)

VPN_ENVS=(stage prod chennai)

# ── Private Helpers ────────────────────────────────────────────────────────────

_vpn_pids_for_env() {
    local env="$1"
    pgrep -f "openfortivpn.*${env}" 2>/dev/null || true
}

_vpn_kill_env() {
    local env="$1"
    local pids
    pids=$(_vpn_pids_for_env "$env")
    if [ -n "$pids" ]; then
        echo "$pids" | xargs sudo kill -9 2>/dev/null
        return 0
    fi
    return 1
}

_vpn_log_file() {
    echo "/tmp/vpn_${1}.log"
}

_vpn_write_config() {
    local env="$1" host="$2" port="$3" username="$4" password="$5" cert="$6"
    local temp_config="/tmp/openfortivpn_${env}.conf"
    cat > "$temp_config" <<-EOF
		host = $host
		port = ${port:-10443}
		username = $username
		password = $password
	EOF
    [ -n "$cert" ] && [ "$cert" != "null" ] && echo "trusted-cert = $cert" >> "$temp_config"
    chmod 600 "$temp_config"
    echo "$temp_config"
}

# ── ProtonPass ─────────────────────────────────────────────────────────────────

get_vpn_config() {
    local env="${1:-stage}"
    local vault="E2E"
    local item

    case "$env" in
        stage|staging)   item="VPN Stage Credentials" ;;
        prod|production) item="VPN Production Credentials" ;;
        vyoma|chennai)   item="VPN SCP - Chennai" ;;
        *)
            echo "Error: Unknown environment '$env'" >&2
            echo "Available: stage, prod, chennai" >&2
            return 1
            ;;
    esac

    echo "Retrieving $env config from ProtonPass..." >&2
    local data
    data=$(pass-cli item view --vault-name "$vault" --item-title "$item" --output json 2>/dev/null) || {
        echo "Error: Failed to retrieve from ProtonPass" >&2
        return 1
    }

    jq -n \
        --arg host "$(echo "$data" | jq -r '.item.content.content.Login.urls[0]' | sed 's|https://||' | sed 's|/$||')" \
        --arg port "$(echo "$data" | jq -r '.item.content.extra_fields[] | select(.name == "port") | .content.Text')" \
        --arg username "$(echo "$data" | jq -r '.item.content.content.Login.username')" \
        --arg password "$(echo "$data" | jq -r '.item.content.content.Login.password')" \
        --arg cert "$(echo "$data" | jq -r '.item.content.extra_fields[] | select(.name == "cert") | .content.Hidden')" \
        '{host: $host, port: $port, username: $username, password: $password, cert: $cert}'
}

# ── Connect ────────────────────────────────────────────────────────────────────

# Usage: vpn_connect [env] [true|false]
vpn_connect() {
    local env="${1:-stage}"
    local background="${2:-false}"

    echo "=== Connecting to $env VPN ==="

    local config_json
    config_json=$(get_vpn_config "$env") || return 1

    local host port username password cert
    host=$(echo "$config_json"     | jq -r '.host')
    port=$(echo "$config_json"     | jq -r '.port')
    username=$(echo "$config_json" | jq -r '.username')
    password=$(echo "$config_json" | jq -r '.password')
    cert=$(echo "$config_json"     | jq -r '.cert')

    if [ -z "$host" ] || [ -z "$password" ]; then
        echo "Error: Missing required config (host or password)" >&2
        return 1
    fi

    echo "✓ Config retrieved — Host: $host:${port:-10443}, User: $username"
    [ -n "$cert" ] && [ "$cert" != "null" ] && echo "  Cert: ${cert:0:20}..."

    if [ "$background" = "true" ] && [ -n "$(_vpn_pids_for_env "$env")" ]; then
        echo "Error: $env VPN is already running. Use vpn_restart_bg $env or vda first." >&2
        return 1
    fi

    local temp_config
    temp_config=$(_vpn_write_config "$env" "$host" "$port" "$username" "$password" "$cert")

    if [ "$background" = "true" ]; then
        local log_file
        log_file=$(_vpn_log_file "$env")
        echo "Connecting in background..."
        nohup sudo openfortivpn -c "$temp_config" > "$log_file" 2>&1 &
        echo "✓ Started in background (Log: $log_file)"
    else
        echo "Connecting..."
        sudo openfortivpn -c "$temp_config"
        rm -f "$temp_config"
    fi
}

vpn_connect_all() {
    echo "=== Starting all VPNs in background ==="
    for env in "${VPN_ENVS[@]}"; do
        vpn_connect "$env" true
        sleep 1
    done
    echo "=== All VPNs started ==="
}

# ── Disconnect ─────────────────────────────────────────────────────────────────

# Usage: vpn_disconnect [env]  (no arg = all)
vpn_disconnect() {
    local env="$1"
    if [ -n "$env" ]; then
        if _vpn_kill_env "$env"; then
            echo "✓ $env disconnected"
        else
            echo "✗ $env was not running"
            return 1
        fi
    else
        echo "=== Disconnecting all VPNs ==="
        for e in "${VPN_ENVS[@]}"; do
            if _vpn_kill_env "$e"; then
                echo "✓ $e disconnected"
            else
                echo "○ $e was not running"
            fi
        done
        rm -f /tmp/openfortivpn_*.conf(N)
        echo "=== All VPNs stopped ==="
    fi
}

vpn_disconnect_all() { vpn_disconnect }

# ── Status ─────────────────────────────────────────────────────────────────────

# Usage: vpn_status [env]  (no arg = all)
vpn_status() {
    local env="$1"
    if [ -n "$env" ]; then
        local pids
        pids=$(_vpn_pids_for_env "$env")
        if [ -n "$pids" ]; then
            echo "✓ $env: Connected (PID: $(echo "$pids" | head -1))"
            [ -f "$(_vpn_log_file "$env")" ] && echo "  Log: $(_vpn_log_file "$env")"
        else
            echo "✗ $env: Disconnected"
            return 1
        fi
    else
        echo "=== VPN Status ==="
        local connected=0 disconnected=0
        for e in "${VPN_ENVS[@]}"; do
            local pids
            pids=$(_vpn_pids_for_env "$e")
            if [ -n "$pids" ]; then
                echo "✓ $e: Connected (PID: $(echo "$pids" | head -1))"
                [ -f "$(_vpn_log_file "$e")" ] && echo "  Log: $(_vpn_log_file "$e")"
                (( connected++ )) || true
            else
                echo "✗ $e: Disconnected"
                (( disconnected++ )) || true
            fi
        done
        echo ""
        echo "Summary: $connected connected, $disconnected disconnected"
    fi
}

vpn_status_all() { vpn_status }

# ── Reconnect ──────────────────────────────────────────────────────────────────

# Usage: vpn_reconnect [env]  (no arg = all)
vpn_reconnect() {
    local env="$1"
    if [ -n "$env" ]; then
        echo "=== Reconnecting $env VPN ==="
        _vpn_kill_env "$env" && sleep 2
        vpn_connect "$env" true   # always background
    else
        echo "=== Reconnecting all VPNs ==="
        vpn_disconnect
        sleep 2
        vpn_connect_all
    fi
}

# ── Logs ───────────────────────────────────────────────────────────────────────

vpn_logs() {
    local env="${1:-stage}"
    local log_file
    log_file=$(_vpn_log_file "$env")
    if [ -f "$log_file" ]; then
        echo "=== $env VPN Log (last 50 lines) ==="
        tail -n 50 "$log_file"
    else
        echo "No log file for $env. Start with: vpn_connect $env true"
    fi
}

vpn_logs_follow() {
    local env="${1:-stage}"
    local log_file
    log_file=$(_vpn_log_file "$env")
    if [ -f "$log_file" ]; then
        echo "=== Following $env VPN Log (Ctrl+C to stop) ==="
        tail -f "$log_file"
    else
        echo "No log file for $env. Start with: vpn_connect $env true"
    fi
}

# ── Aliases ────────────────────────────────────────────────────────────────────

alias vca="vpn_connect_all"
alias vda="vpn_disconnect_all"
alias vra="vpn_reconnect"
